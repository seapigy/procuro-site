{
  "name": "procuro-app",
  "version": "1.0.0",
  "description": "QuickBooks-integrated price-monitoring SaaS",
  "private": true,
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev:server": "npm run dev --workspace=server",
    "dev:client": "npm run dev --workspace=client",
    "build": "npm run build --workspace=server && npm run build --workspace=client",
    "build:render": "npm run build --workspace=client",
    "start": "npm run start --workspace=server",
    "start:render": "npm run start:runtime --workspace=server",
    "install:all": "npm install --include=dev && npm install --workspace=server --include=dev && npm install --workspace=client --include=dev"
  },
  "keywords": [
    "price-monitoring",
    "quickbooks",
    "saas"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "node-fetch": "^2.7.0"
  }
}
