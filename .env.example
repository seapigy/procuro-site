# Database
DATABASE_URL=postgresql://user:password@localhost:5432/procuroapp?schema=public
# For SQLite (development):
# DATABASE_URL=file:./dev.db

# QuickBooks Integration
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REDIRECT_URI=http://localhost:5000/api/qb/callback
QUICKBOOKS_ENVIRONMENT=sandbox

# Retailer APIs - Amazon
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
AMAZON_REGION=us-east-1

# Bright Data Datasets API (Amazon price data)
BRIGHTDATA_API_KEY=
BRIGHTDATA_DATASET_ID=
# Or legacy: BRIGHTDATA_AMAZON_DATASET_ID=
# Optional: BRIGHTDATA_API_HOST=https://api.brightdata.com
# Optional: BRIGHTDATA_AMAZON_DISCOVERY_TIMEOUT_MS=120000 (default 120s, was 55s)
# Cap rows returned per keyword (Bright Data limit_per_input; clamped 1–100, default 30)
# BRIGHTDATA_LIMIT_PER_INPUT=15
# How many discovery rows to score: first pass / escalation (clamped 1–100; escalation >= first pass)
# BRIGHTDATA_AMAZON_MATCH_DEPTH=20
# BRIGHTDATA_AMAZON_MATCH_DEPTH_ESCALATION=50
BRIGHTDATA_ENABLED=false
# Home Depot (Bright Data). Requires BRIGHTDATA_API_KEY. Dataset id e.g. gd_...
# Keyword mode: discover_by=keyword + input keyword (see homeDepotBrightDataProvider). PDP: pass full product URL as name.
# BRIGHTDATA_HOMEDEPOT_DATASET_ID=
# BRIGHTDATA_HOMEDEPOT_DISCOVERY_TIMEOUT_MS=120000
# BRIGHTDATA_HOMEDEPOT_MAX_RETRIES=3
# BRIGHTDATA_DEBUG_CAPTURE=true  # When true, save raw response samples to BrightDataRawSample for tuning Amazon parsing
# USE_MOCK_PROVIDER=true  # Set to force mock provider in dev (default: mock in dev, Amazon when Bright Data configured)

# Discovery routing (optional)
# GLOBAL_DISCOVERY_PROFILES_ENABLED=true  # Cross-tenant hashed product keys + win counts + hint strings
# DISCOVERY_SKIP_AMAZON_AFTER_HD=true     # After HD returns valid quotes in a run, skip Amazon (saves BD cost)

# Server Configuration
NODE_ENV=development
PORT=5000
SERVER_URL=http://localhost:5000
# Allow /api/test and /api/debug (including /api/debug/context) in production — default is disabled (404)
# ALLOW_TEST_ROUTES=true

# Client Configuration
CLIENT_URL=http://localhost:5173

# JWT Secret (for authentication tokens)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# QuickBooks import: purchases (default lookback 365d) and retailer/Bright Data matching only for the top N
# distinct item names by line frequency in that window; garbage names (e.g. BILL-1234) never match.
# QB_IMPORT_PURCHASE_LOOKBACK_DAYS=365
# QB_IMPORT_MATCH_TOP_N=20
# Set true to disable all import-time retailer matching (overrides MATCH_TOP_N).
# QB_IMPORT_SKIP_RETAILER_MATCH=true
# Mark ImportRun stuck in running longer than N minutes as error on startup / admin refresh (default 5).
# IMPORT_RUN_STALE_RUNNING_MINUTES=5

# Admin portal (Phase 1)
ADMIN_PORTAL_ENABLED=false
ADMIN_OWNER_EMAILS=
GOOGLE_ADMIN_CLIENT_ID=
ADMIN_PORTAL_SESSION_SECRET=
# Optional
# ADMIN_PORTAL_SESSION_MAX_AGE_SECONDS=86400
# ADMIN_IMPORT_SLOW_THRESHOLD_MS=60000

# Stripe billing ($49/mo etc. — use Price ID from Stripe Dashboard)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PRICE_ID_MONTHLY=price_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# FRONTEND_URL=http://localhost:5173
# STRIPE_BILLING_PORTAL_RETURN_URL=http://localhost:5173/settings
