// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// For local SQLite (optional): set provider = "sqlite" and DATABASE_URL = "file:./prisma/dev.db"

model Company {
  id                  Int      @id @default(autoincrement())
  name                String?
  realmId             String?  @unique
  createdAt           DateTime @default(now())
  // Stripe billing fields
  isSubscribed        Boolean  @default(false)
  stripeCustomerId    String?
  stripeSubscriptionId String?
  paymentMethodAddedAt DateTime?
  trialStartedAt      DateTime?
  trialEndsAt         DateTime?
  importCompletedAt   DateTime?
  importLastAttemptedAt DateTime?
  // QuickBooks connection status
  isQuickBooksConnected Boolean @default(false)
  lastImportedItemCount Int?
  connectionBrokenAt    DateTime?

  users   User[]
  invites Invite[]
  items   Item[]
  importRuns ImportRun[]
  adminAuditLogs AdminAuditLog[]
  retailerPriceQuotes RetailerPriceQuote[]
  itemRetailerMatches ItemRetailerMatch[]

  @@index([realmId])
  @@index([stripeCustomerId])
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Company relationship
  companyId Int?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // QuickBooks integration
  quickbooksId           String?
  quickbooksAccessToken  String?
  quickbooksRefreshToken String?
  quickbooksRealmId      String?
  quickbooksConnectedAt  DateTime?
  onboardingCompleted    Boolean  @default(false)

  items          Item[]
  alerts         Alert[]
  savingsSummary SavingsSummary[]
  importRuns     ImportRun[]
  adminAuditLogs AdminAuditLog[]

  @@index([companyId])
}

model Item {
  id                  Int      @id @default(autoincrement())
  userId              Int
  companyId           Int      // Tenant isolation (required for RLS)
  name                String
  sku                 String?
  category            String?
  baselinePrice       Float?    // Legacy; prefer baselineUnitPrice for savings
  baselineUnitPrice   Float?    // Sticky baseline (P90 from QB history) used for savings
  baselineSetAt       DateTime? // When baseline was established
  baselineSource      String?   // 'qb_p90', 'qb_max_fallback', 'manual', etc.
  bestDealUnitPrice   Float?    // Lowest observed price since baseline set
  bestDealFoundAt     DateTime?
  bestDealRetailer    String?
  bestDealUrl         String?
  lastPaidPrice       Float     // Most recent per-unit paid price from QB (line amount/qty); used for display and retail/Amazon matching reference, not for baseline savings
  lastCheckedPrice    Float?
  quantityPerOrder    Int      @default(1)
  reorderIntervalDays Int      @default(30)
  vendorName          String?
  /// Product brand on package (not the same as vendor/supplier).
  productBrand        String?
  /// Optional Amazon/Bright Data search phrase; does not replace accounting item name.
  amazonSearchHint    String?
  upc                 String?
  matchedRetailer     String?
  matchedUrl          String?
  matchedPrice        Float?
  matchConfidence     Float?   // 0.0 to 1.0 - confidence score from matching algorithm
  isVagueName         Boolean  @default(false) // Flag if name is too generic/vague
  needsClarification   Boolean  @default(false) // Flag if user should improve name for better matching
  // Enhanced Matching Accuracy fields
  normalizedName      String?  // Store normalized/cleaned name for matching
  matchStatus         String   @default("unmatched") // unmatched | auto_matched | needs_review | verified | overridden
  matchProvider       String?  // e.g. "officedepot"
  matchUrl            String?  // Canonical product URL (alternative to matchedUrl for consistency)
  matchTitle          String?  // Title of matched product
  matchPrice          Float?   // Last matched candidate price (alternative to matchedPrice)
  matchReasons        Json?    // JSON array/object of reasons for transparency
  isManuallyMatched   Boolean  @default(false) // If manually matched, prevents auto-overwrites
  manualMatchProvider String?  // Provider for manual match
  manualMatchUrl      String?  // URL for manual match
  manualMatchTitle    String?  // Title for manual match
  manualMatchNotes    String?  // Optional notes for manual match
  lastMatchedAt       DateTime? // Last time matching was performed
  // Amazon product matching (manually added columns)
  amazonAsin          String?
  amazonProductUrl    String?
  amazonMatchedAt     DateTime?
  // Smart Monitoring Engine fields
  purchaseCount        Int      @default(0)     // how many times this item has been purchased (QuickBooks)
  firstPurchasedAt     DateTime?                 // first time we saw a purchase for this item
  lastPurchasedAt      DateTime?                 // most recent purchase date
  estimatedMonthlyUnits Float?   @default(0)     // rough estimate of units/month
  priorityScore        Float     @default(0)     // computed monitoring priority
  isMonitored          Boolean   @default(false) // whether it's in the top-N monitored set
  isPaused             Boolean   @default(false) // whether monitoring is paused by user
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company  Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  prices Price[]
  alerts Alert[]
  priceHistory PriceHistory[]
  retailerPriceQuotes RetailerPriceQuote[]
  itemRetailerMatches ItemRetailerMatch[]

  @@index([userId])
  @@index([companyId])
}

model Price {
  id        Int      @id @default(autoincrement())
  itemId    Int
  companyId Int      // Tenant isolation (required for RLS)
  retailer  String
  price     Float
  url       String?
  date      DateTime @default(now())

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@index([companyId])
  @@index([retailer])
  @@index([date])
}

model Alert {
  id                      Int      @id @default(autoincrement())
  itemId                  Int
  userId                  Int
  companyId               Int      // Tenant isolation (required for RLS)
  retailer                String
  newPrice                Float
  oldPrice                Float
  priceDropAmount         Float
  url                     String?
  savingsPerOrder         Float
  estimatedMonthlySavings Float
  seen                    Boolean  @default(false)
  viewed                  Boolean  @default(false)
  alertDate               DateTime @default(now())
  dateTriggered           DateTime @default(now())

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@index([userId])
  @@index([companyId])
  @@index([alertDate])
  @@index([seen])
}

model SavingsSummary {
  id             Int      @id @default(autoincrement())
  userId         Int
  companyId      Int      // Tenant isolation (required for RLS)
  monthlyTotal   Float    @default(0)
  yearToDate     Float    @default(0)
  lastCalculated DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([companyId])
}

model Invite {
  id        Int      @id @default(autoincrement())
  companyId Int
  token     String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime
  used      Boolean  @default(false)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([expiresAt])
  @@index([companyId])
}

model PriceHistory {
  id        Int      @id @default(autoincrement())
  itemId    Int
  companyId Int      // Tenant isolation (required for RLS)
  price     Float
  retailer  String
  createdAt DateTime @default(now())

  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@index([companyId])
  @@index([createdAt])
}

model RetailerPriceQuote {
  id        Int      @id @default(autoincrement())
  companyId Int
  itemId    Int
  retailer  String
  url       String?
  unitPrice Float
  currency  String   @default("USD")
  capturedAt DateTime @default(now())
  rawJson   Json?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  item    Item    @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([companyId, itemId, capturedAt])
  @@index([companyId, capturedAt])
}

model BrightDataScrapeJob {
  id            Int       @id @default(autoincrement())
  companyId     Int
  itemId        Int
  provider      String
  snapshotId    String    @unique
  status        String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastCheckedAt DateTime?
  error         String?

  @@index([companyId, status])
  @@index([itemId, status])
}

model BrightDataRawSample {
  id         Int      @id @default(autoincrement())
  provider   String
  companyId  Int
  itemId     Int
  capturedAt DateTime @default(now())
  inputUrl   String?
  rowsJson   Json?
  statusCode Int?
  notes      String?

  @@index([provider, itemId])
  @@index([companyId])
}

/// Multi-retailer architecture: one item can have matches at multiple retailers.
/// Replaces retailer-specific Item columns (e.g. amazonAsin) long-term.
model ItemRetailerMatch {
  id                Int       @id @default(autoincrement())
  itemId            Int
  companyId         Int
  retailer          String
  retailerProductId String?
  productUrl        String?
  matchedAt         DateTime?
  matchConfidence   Float?
  matchTitle        String?
  matchBrand        String?
  isActive          Boolean   @default(true)
  lastCheckedAt     DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  item    Item    @relation(fields: [itemId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([itemId, retailer])
  @@index([itemId, retailer])
  @@index([companyId, retailer])
}

/// Cross-tenant anonymized discovery hints (hashed product key only — no company PII).
model ItemDiscoveryProfile {
  key                  String    @id @db.VarChar(64)
  hdWinCount           Int       @default(0)
  amazonWinCount       Int       @default(0)
  homeDepotSearchHint  String?
  amazonSearchHint     String?
  lastReinforcedAt     DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

model ImportRun {
  id                Int       @id @default(autoincrement())
  companyId         Int
  userId            Int?
  source            String
  status            String
  startedAt         DateTime  @default(now())
  finishedAt        DateTime?
  durationMs        Int?
  importedItemCount Int       @default(0)
  errorCode         String?
  errorMessage      String?
  realmId           String?
  metadata          Json?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([companyId, startedAt(sort: Desc)])
  @@index([status, startedAt(sort: Desc)])
  @@index([startedAt(sort: Desc)])
}

model AdminAuditLog {
  id            Int      @id @default(autoincrement())
  adminEmail    String
  action        String
  endpoint      String
  method        String
  targetCompanyId Int?
  success       Boolean  @default(true)
  errorCode     String?
  correlationId String?
  metadata      Json?
  createdAt     DateTime @default(now())
  companyId     Int?
  userId        Int?

  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([adminEmail, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
  @@index([targetCompanyId, createdAt(sort: Desc)])
}
